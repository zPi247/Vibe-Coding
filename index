;\n      flex-direction: column;\n      align-items: center;\n      width: 80vw;\n      height: 80vh;\n      gap: 0;\n    }\n\n    h1 {\n      font-family: 'Space Grotesk', sans-serif;\n      font-size: clamp(2.5rem, 5vw, 4rem);\n      color: rgba(255, 255, 255, 0.92);\n      font-weight: 300;\n      letter-spacing: -1px;\n      margin-bottom: 0.75rem;\n      flex-shrink: 0;\n    }\n\n    .keyword-badge {\n      font-family: 'Space Grotesk', sans-serif;\n      font-size: 0.7rem;\n      font-weight: 500;\n      color: rgba(100, 210, 255, 0.7);\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      height: 1.4rem;\n      margin-bottom: 0.5rem;\n      opacity: 0;\n      transition: opacity 0.3s ease;\n      flex-shrink: 0;\n    }\n\n    .keyword-badge.active {\n      opacity: 1;\n    }\n\n    textarea {\n      flex: 1;\n      width: 100%;\n      padding: 2rem;\n      font-size: clamp(1.2rem, 2.2vw, 1.8rem);\n      font-family: 'Space Grotesk', sans-serif;\n      font-weight: 300;\n      border: none;\n      background: transparent;\n      color: rgba(255, 255, 255, 0.85);\n      resize: none;\n      outline: none;\n      caret-color: #64d2ff;\n      line-height: 1.75;\n      text-align: center;\n    }\n\n    textarea::placeholder {\n      color: rgba(255, 255, 255, 0.18);\n    }\n\n    /* Divider */\n    .divider {\n      width: 100%;\n      height: 1px;\n      background: rgba(255, 255, 255, 0.06);\n      flex-shrink: 0;\n      margin-bottom: 0.6rem;\n    }\n\n    /* Menu */\n    .menu-grid {\n      display: flex;\n      flex-direction: row;\n      flex-wrap: wrap;\n      gap: 0.4rem;\n      justify-content: center;\n      flex-shrink: 0;\n      padding-bottom: 0.25rem;\n    }\n\n    .menu-item {\n      padding: 0.3rem 0.75rem;\n      background: transparent;\n      border: 1px solid rgba(100, 150, 255, 0.2);\n      color: rgba(150, 200, 255, 0.6);\n      border-radius: 20px;\n      font-size: 0.72rem;\n      font-family: 'Space Grotesk', sans-serif;\n      font-weight: 400;\n      letter-spacing: 0.3px;\n      cursor: pointer;\n      transition: all 0.15s ease;\n      user-select: none;\n    }\n\n    .menu-item:hover {\n      background: rgba(100, 150, 255, 0.1);\n      border-color: rgba(100, 150, 255, 0.4);\n      color: rgba(200, 220, 255, 0.9);\n    }\n\n    .menu-item.active {\n      background: rgba(100, 180, 255, 0.15);\n      border-color: rgba(100, 210, 255, 0.6);\n      color: #fff;\n    }\n  <\u002Fstyle>\n  \n<\u002Fhead>\n<body>\n  <canvas id=\"bgCanvas\"><\u002Fcanvas>\n  <canvas id=\"particleCanvas\"><\u002Fcanvas>\n\n  <div class=\"container\">\n    <h1>what's the weather?<\u002Fh1>\n    <div class=\"keyword-badge\" id=\"keywordBadge\"><\u002Fdiv>\n    <textarea id=\"textInput\" placeholder=\"describe the weather…\" spellcheck=\"false\"><\u002Ftextarea>\n    <div class=\"divider\"><\u002Fdiv>\n    <div class=\"menu-grid\" id=\"menuGrid\"><\u002Fdiv>\n  <\u002Fdiv>\n\n  <script>\n    // ============================================\n    // COSMIC BACKGROUND\n    // ============================================\n    const bgCanvas = document.getElementById('bgCanvas');\n    const bgCtx = bgCanvas.getContext('2d');\n\n    function resizeBg() {\n      bgCanvas.width = window.innerWidth;\n      bgCanvas.height = window.innerHeight;\n    }\n    resizeBg();\n\n    // Generate stars\n    const stars = [];\n    function generateStars() {\n      stars.length = 0;\n      const count = Math.floor((bgCanvas.width * bgCanvas.height) / 2500);\n      for (let i = 0; i < count; i++) {\n        stars.push({\n          x: Math.random() * bgCanvas.width,\n          y: Math.random() * bgCanvas.height,\n          r: Math.random() * 1.4 + 0.2,\n          alpha: Math.random() * 0.8 + 0.2,\n          twinkleSpeed: Math.random() * 0.02 + 0.005,\n          twinkleOffset: Math.random() * Math.PI * 2\n        });\n      }\n    }\n    generateStars();\n\n    // Nebulae\n    const nebulae = [\n      { x: 0.15, y: 0.25, r: 0.35, color: [80, 60, 200] },\n      { x: 0.80, y: 0.65, r: 0.30, color: [180, 40, 140] },\n      { x: 0.50, y: 0.80, r: 0.25, color: [40, 100, 200] },\n      { x: 0.70, y: 0.15, r: 0.20, color: [60, 150, 255] },\n    ];\n\n    // Shooting stars for background ambiance\n    const shootingStars = [];\n    function spawnShootingStar() {\n      if (shootingStars.length < 3 && Math.random() < 0.004) {\n        shootingStars.push({\n          x: Math.random() * bgCanvas.width * 0.7,\n          y: Math.random() * bgCanvas.height * 0.5,\n          len: Math.random() * 120 + 60,\n          speed: Math.random() * 4 + 3,\n          alpha: 1,\n          life: 1\n        });\n      }\n    }\n\n    let bgTime = 0;\n    function drawBg() {\n      bgCtx.clearRect(0, 0, bgCanvas.width, bgCanvas.height);\n      bgTime += 0.016;\n\n      // Deep space gradient\n      const grad = bgCtx.createRadialGradient(\n        bgCanvas.width * 0.5, bgCanvas.height * 0.4, 0,\n        bgCanvas.width * 0.5, bgCanvas.height * 0.5, bgCanvas.width * 0.8\n      );\n      grad.addColorStop(0, '#0c1428');\n      grad.addColorStop(0.5, '#060c1c');\n      grad.addColorStop(1, '#02040f');\n      bgCtx.fillStyle = grad;\n      bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);\n\n      // Nebulae\n      nebulae.forEach(n => {\n        const grd = bgCtx.createRadialGradient(\n          n.x * bgCanvas.width, n.y * bgCanvas.height, 0,\n          n.x * bgCanvas.width, n.y * bgCanvas.height, n.r * bgCanvas.width\n        );\n        grd.addColorStop(0, `rgba(${n.color[0]},${n.color[1]},${n.color[2]},0.12)`);\n        grd.addColorStop(0.4, `rgba(${n.color[0]},${n.color[1]},${n.color[2]},0.05)`);\n        grd.addColorStop(1, `rgba(${n.color[0]},${n.color[1]},${n.color[2]},0)`);\n        bgCtx.fillStyle = grd;\n        bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);\n      });\n\n      // Stars with twinkle\n      stars.forEach(s => {\n        const twinkle = 0.5 + 0.5 * Math.sin(bgTime * s.twinkleSpeed * 60 + s.twinkleOffset);\n        bgCtx.globalAlpha = s.alpha * (0.4 + 0.6 * twinkle);\n        bgCtx.fillStyle = '#ffffff';\n        bgCtx.beginPath();\n        bgCtx.arc(s.x, s.y, s.r, 0, Math.PI * 2);\n        bgCtx.fill();\n      });\n      bgCtx.globalAlpha = 1;\n\n      // Distant star clusters — slightly brighter tiny dots\n      for (let i = 0; i < 3; i++) {\n        const cx = [0.2, 0.6, 0.85][i] * bgCanvas.width;\n        const cy = [0.3, 0.7, 0.2][i] * bgCanvas.height;\n        const clusterGrad = bgCtx.createRadialGradient(cx, cy, 0, cx, cy, 80);\n        clusterGrad.addColorStop(0, 'rgba(200, 220, 255, 0.06)');\n        clusterGrad.addColorStop(1, 'rgba(200, 220, 255, 0)');\n        bgCtx.fillStyle = clusterGrad;\n        bgCtx.beginPath();\n        bgCtx.arc(cx, cy, 80, 0, Math.PI * 2);\n        bgCtx.fill();\n      }\n\n      // Shooting stars\n      spawnShootingStar();\n      for (let i = shootingStars.length - 1; i >= 0; i--) {\n        const ss = shootingStars[i];\n        ss.x += ss.speed * 1.5;\n        ss.y += ss.speed * 0.6;\n        ss.life -= 0.018;\n        ss.alpha = ss.life;\n        if (ss.life <= 0) { shootingStars.splice(i, 1); continue; }\n        const tail = bgCtx.createLinearGradient(ss.x, ss.y, ss.x - ss.len, ss.y - ss.len * 0.4);\n        tail.addColorStop(0, `rgba(255, 255, 255, ${ss.alpha * 0.9})`);\n        tail.addColorStop(1, 'rgba(255,255,255,0)');\n        bgCtx.strokeStyle = tail;\n        bgCtx.lineWidth = 1.5;\n        bgCtx.beginPath();\n        bgCtx.moveTo(ss.x, ss.y);\n        bgCtx.lineTo(ss.x - ss.len, ss.y - ss.len * 0.4);\n        bgCtx.stroke();\n      }\n\n      requestAnimationFrame(drawBg);\n    }\n    drawBg();\n\n    // ============================================\n    // PARTICLE SYSTEM\n    // ============================================\n    const canvas = document.getElementById('particleCanvas');\n    const ctx = canvas.getContext('2d');\n\n    canvas.width = window.innerWidth;\n    canvas.height = window.innerHeight;\n\n    const textInput = document.getElementById('textInput');\n    const keywordBadge = document.getElementById('keywordBadge');\n    const menuGrid = document.getElementById('menuGrid');\n\n    let particles = [];\n    let currentEffect = null;\n    let lastMatchedKeyword = null;\n\n    const weatherKeywords = {\n      rain: { display: 'Rain' },\n      thunderstorm: { display: 'Thunderstorm' },\n      snow: { display: 'Snow' },\n      hail: { display: 'Hail' },\n      aurora: { display: 'Aurora' },\n      'meteor shower': { display: 'Meteor Shower' },\n      frost: { display: 'Frost' },\n      rainbow: { display: 'Rainbow' },\n      dew: { display: 'Dew' }\n    };\n\n    // Build menu\n    Object.entries(weatherKeywords).forEach(([keyword, data]) => {\n      const btn = document.createElement('button');\n      btn.className = 'menu-item';\n      btn.textContent = data.display;\n      btn.addEventListener('click', () => {\n        textInput.value = keyword;\n        textInput.dispatchEvent(new Event('input'));\n      });\n      menuGrid.appendChild(btn);\n    });\n\n    // ============================================\n    // PARTICLE CLASS\n    // ============================================\n    class Particle {\n      constructor(x, y, vx, vy, life, color, size, type = 'circle', glow = false, dreamy = false) {\n        this.x = x; this.y = y;\n        this.vx = vx; this.vy = vy;\n        this.life = life; this.maxLife = life;\n        this.color = color; this.size = size;\n        this.alpha = 1; this.type = type;\n        this.glow = glow; this.dreamy = dreamy;\n        this.rotation = Math.random() * Math.PI * 2;\n        this.rotationSpeed = (Math.random() - 0.5) * 0.12;\n        this.gravity = 0;\n      }\n\n      update() {\n        this.vy += this.gravity;\n        this.x += this.vx;\n        this.y += this.vy;\n        this.life -= 1;\n        const t = Math.max(0, this.life / this.maxLife);\n        // Dreamy ease-out for aurora/rainbow, linear otherwise\n        this.alpha = this.dreamy\n          ? t < 0.15 ? t / 0.15 : t  // fade in then ease out\n          : t;\n        this.rotation += this.rotationSpeed;\n      }\n\n      draw(c) {\n        c.save();\n        c.globalAlpha = this.alpha;\n        if (this.glow) {\n          c.shadowColor = this.color;\n          c.shadowBlur = this.size * 3;\n        }\n        c.fillStyle = this.color;\n        if (this.type === 'circle') {\n          c.beginPath();\n          c.arc(this.x, this.y, this.size, 0, Math.PI * 2);\n          c.fill();\n        } else if (this.type === 'star') {\n          this.drawStar(c);\n        } else if (this.type === 'square') {\n          c.translate(this.x, this.y);\n          c.rotate(this.rotation);\n          c.fillRect(-this.size, -this.size, this.size * 2, this.size * 2);\n        } else if (this.type === 'teardrop') {\n          c.translate(this.x, this.y);\n          c.rotate(Math.atan2(this.vy, this.vx) + Math.PI / 2);\n          c.beginPath();\n          c.ellipse(0, 0, this.size * 0.4, this.size * 1.2, 0, 0, Math.PI * 2);\n          c.fill();\n        }\n        c.restore();\n      }\n\n      drawStar(c) {\n        const spikes = 4, outer = this.size, inner = this.size * 0.4;\n        c.save();\n        c.translate(this.x, this.y);\n        c.rotate(this.rotation);\n        c.beginPath();\n        c.moveTo(0, -outer);\n        for (let i = 0; i < spikes * 2; i++) {\n          const r = i % 2 === 0 ? outer : inner;\n          const a = (i * Math.PI) / spikes;\n          c.lineTo(Math.sin(a) * r, -Math.cos(a) * r);\n        }\n        c.closePath();\n        c.fill();\n        c.restore();\n      }\n\n      isAlive() { return this.life > 0; }\n    }\n\n    // ============================================\n    // EFFECT GENERATORS\n    // ============================================\n    const effects = {\n      rain: () => {\n        const x = Math.random() * canvas.width;\n        const vy = Math.random() * 6 + 8;\n        const vx = (Math.random() - 0.5) * 2;\n        const p = new Particle(x, -10, vx, vy,\n          Math.random() * 80 + 60,\n          `hsl(200, 90%, ${50 + Math.random() * 20}%)`,\n          Math.random() * 2.5 + 1.5, 'teardrop', true);\n        particles.push(p);\n        // Splash at bottom\n        if (Math.random() < 0.2) {\n          for (let i = 0; i < 4; i++) {\n            const sx = x + (Math.random() - 0.5) * 20;\n            const sp = new Particle(sx, canvas.height - 5,\n              (Math.random() - 0.5) * 4, -(Math.random() * 3 + 1),\n              Math.random() * 30 + 15,\n              `hsl(200, 90%, 70%)`,\n              Math.random() * 2 + 1, 'circle', false);\n            sp.gravity = 0.15;\n            particles.push(sp);\n          }\n        }\n      },\n\n      thunderstorm: () => {\n        if (Math.random() < 0.65) {\n          const p = new Particle(Math.random() * canvas.width, -10,\n            (Math.random() - 0.5) * 5, Math.random() * 7 + 8,\n            90, `hsl(230, 50%, ${30 + Math.random() * 20}%)`,\n            Math.random() * 2 + 1, 'teardrop', false);\n          particles.push(p);\n        } else {\n          // Electric spark\n          const x = Math.random() * canvas.width;\n          const y = Math.random() * canvas.height * 0.5;\n          for (let i = 0; i < 3; i++) {\n            const p = new Particle(x, y,\n              (Math.random() - 0.5) * 14, (Math.random() - 0.5) * 14,\n              Math.random() * 40 + 20,\n              Math.random() < 0.5 ? '#fff9a0' : '#a0f0ff',\n              Math.random() * 3 + 2, 'star', true);\n            particles.push(p);\n          }\n        }\n      },\n\n      snow: () => {\n        const x = Math.random() * canvas.width;\n        const p = new Particle(x, -10,\n          Math.sin(Date.now() * 0.0004 + x * 0.008) * 1.2, Math.random() * 1.5 + 0.8,\n          Math.random() * 300 + 400,\n          `rgba(${200 + Math.random() * 55}, ${220 + Math.random() * 35}, 255, 0.9)`,\n          Math.random() * 4 + 2, 'star', true);\n        particles.push(p);\n      },\n\n      hail: () => {\n        const x = Math.random() * canvas.width;\n        const p = new Particle(x, -10,\n          (Math.random() - 0.5) * 7, Math.random() * 10 + 10,\n          Math.random() * 80 + 60,\n          `hsl(200, 60%, ${60 + Math.random() * 30}%)`,\n          Math.random() * 4 + 2, 'square', true);\n        p.gravity = 0.3;\n        particles.push(p);\n      },\n\n      aurora: () => {\n        const band = Math.floor(Math.random() * 3);\n        const bandY = [0.15, 0.28, 0.38][band] * canvas.height;\n        const x = Math.random() * canvas.width;\n        const waveY = bandY + Math.sin(Date.now() * 0.0006 + x * 0.008) * 40;\n        const hue = (140 + band * 60 + Math.random() * 50) % 360;\n        const p = new Particle(\n          x, waveY,\n          (Math.random() - 0.5) * 1.5,\n          Math.sin(Date.now() * 0.0008 + x * 0.01) * 0.8,\n          Math.random() * 280 + 200,\n          `hsla(${hue}, 100%, 75%, 0.55)`,\n          Math.random() * 3 + 1, 'circle', true, true);\n        particles.push(p);\n      },\n\n      'meteor shower': () => {\n        const x = Math.random() * canvas.width * 0.8;\n        const y = Math.random() * canvas.height * 0.4;\n        const speed = Math.random() * 14 + 10;\n        const angle = Math.PI * 0.35 + Math.random() * 0.2;\n        const p = new Particle(x, y,\n          Math.cos(angle) * speed, Math.sin(angle) * speed,\n          Math.random() * 60 + 40,\n          `hsl(${30 + Math.random() * 30}, 100%, ${60 + Math.random() * 30}%)`,\n          Math.random() * 4 + 2, 'star', true);\n        particles.push(p);\n        // Tail\n        for (let i = 1; i <= 4; i++) {\n          const tp = new Particle(x - Math.cos(angle) * speed * i * 1.5,\n            y - Math.sin(angle) * speed * i * 1.5,\n            Math.cos(angle) * (speed - i * 1.5), Math.sin(angle) * (speed - i * 1.5),\n            Math.random() * 20 + 10,\n            `hsla(${30 + Math.random() * 30}, 100%, 80%, 0.4)`,\n            Math.random() * 2 + 1, 'circle', false);\n          particles.push(tp);\n        }\n      },\n\n      frost: () => {\n        const cx = canvas.width / 2, cy = canvas.height / 2;\n        const angle = Math.random() * Math.PI * 2;\n        const dist = Math.random() * 300 + 100;\n        const p = new Particle(\n          cx + Math.cos(angle) * dist, cy + Math.sin(angle) * dist,\n          Math.cos(angle) * 2.5, Math.sin(angle) * 2.5,\n          Math.random() * 160 + 100,\n          `hsl(${190 + Math.random() * 30}, 100%, ${70 + Math.random() * 25}%)`,\n          Math.random() * 5 + 2, 'star', true);\n        particles.push(p);\n      },\n\n      rainbow: () => {\n        const arcProgress = Math.random();\n        const arcX = arcProgress * canvas.width;\n        const arcDepth = canvas.height * 0.32;\n        const arcY = arcDepth - Math.sin(arcProgress * Math.PI) * arcDepth * 0.7\n                    + (Math.random() - 0.5) * 40;\n        const hue = arcProgress * 300;\n        const p = new Particle(\n          arcX, arcY,\n          (Math.random() - 0.5) * 1.2, -(Math.random() * 0.6 + 0.1),\n          Math.random() * 180 + 140,\n          `hsla(${hue}, 100%, 68%, 0.75)`,\n          Math.random() * 2.5 + 0.8, 'circle', true, true);\n        particles.push(p);\n      },\n\n      dew: () => {\n        const p = new Particle(\n          Math.random() * canvas.width,\n          Math.random() * canvas.height,\n          (Math.random() - 0.5) * 1.2, (Math.random() - 0.5) * 1.2,\n          Math.random() * 120 + 80,\n          `hsl(${190 + Math.random() * 40}, 90%, ${75 + Math.random() * 20}%)`,\n          Math.random() * 3 + 1.5, 'circle', true);\n        particles.push(p);\n      }\n    };\n\n    // ============================================\n    // KEYWORD DETECTION\n    // ============================================\n    function detectKeyword(text) {\n      const lower = text.toLowerCase();\n      const sorted = Object.keys(weatherKeywords).sort((a, b) => b.length - a.length);\n      for (const kw of sorted) {\n        if (lower.includes(kw)) return kw;\n      }\n      return null;\n    }\n\n    function updateUI(keyword) {\n      keywordBadge.textContent = keyword ? weatherKeywords[keyword].display : '';\n      keyword ? keywordBadge.classList.add('active') : keywordBadge.classList.remove('active');\n      document.querySelectorAll('.menu-item').forEach(btn => {\n        btn.classList.toggle('active', btn.textContent === (keyword ? weatherKeywords[keyword].display : ''));\n      });\n    }\n\n    textInput.addEventListener('input', e => {\n      const kw = detectKeyword(e.target.value);\n      if (kw !== lastMatchedKeyword) {\n        lastMatchedKeyword = kw;\n        currentEffect = kw;\n        updateUI(kw);\n        if (!kw) particles = [];\n      }\n    });\n\n    // ============================================\n    // ANIMATION LOOP\n    // ============================================\n    function animate() {\n      ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n      if (currentEffect && effects[currentEffect]) {\n        const countMap = { dew: 2, 'meteor shower': 1, aurora: 6, rainbow: 5 };\n        const count = countMap[currentEffect] ?? 3;\n        for (let i = 0; i < count; i++) effects[currentEffect]();\n      }\n\n      particles = particles.filter(p => p.isAlive());\n      for (const p of particles) { p.update(); p.draw(ctx); }\n\n      requestAnimationFrame(animate);\n    }\n\n    window.addEventListener('resize', () => {\n      canvas.width = window.innerWidth;\n      canvas.height = window.innerHeight;\n      bgCanvas.width = window.innerWidth;\n      bgCanvas.height = window.innerHeight;\n      generateStars();\n    });\n\n    animate();\n  <\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>
